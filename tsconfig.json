{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["es2021", "es2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "types": ["node"],
    "esModuleInterop": true,
    "incremental": true,
    "declaration": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["./src"]
}
